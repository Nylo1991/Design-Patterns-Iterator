<Window x:Class="AppIterator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AppIterator.ViewModels"
        Title="Demonstração Iterator"
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Background="#1E1E1E">
        <StackPanel Margin="20">

            <TextBlock Text="Simulação do Iterator"
                       FontSize="24"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <Button Content="▶ Executar Iterator"
                    Command="{Binding ExecutarCommand}"
                    Height="40"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    Margin="0 0 0 20"/>

            <ListBox ItemsSource="{Binding Logs}"
                     Background="#2D2D2D"
                     Foreground="White"
                     FontSize="16"
                     BorderThickness="0"/>

        </StackPanel>
    </Grid>
</Window>